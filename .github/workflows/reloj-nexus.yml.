name: Reloj del Robot Nexus
on:
  schedule:
    - cron: '0 * * * *' # Esto hace que revise cada hora exacta
  workflow_dispatch: # Esto permite que lo actives tú cuando quieras

jobs:
  ejecutar-robot:
    runs-on: ubuntu-latest
    steps:
      - name: Descargar codigo
        uses: actions/checkout@v3
      - name: Instalar Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.9'
      - name: Instalar librerias
        run: pip install requests beautifulsoup4 supabase
      - name: Correr Robot
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
        run: python bot.py

